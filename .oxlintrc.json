{
  "$schema": "./node_modules/oxlint/configuration_schema.json",

  "ignorePatterns": [
    "**/node_modules/",
    "dist/",
    "quasar.config.*.temporary.compiled*",
    ".quasar/",
    "src-cordova/",
    "src-capacitor/"
  ],

  "options": {
    "maxWarnings": 10
  },

  "plugins": ["vue", "import", "eslint", "promise", "unicorn"],

  "categories": {
    "correctness": "error"
    // "style": "error",
    // "pedantic": "warn",
    // "suspicious": "error",
    // "perf": "error",
    // "restriction": "error"
  },

  "rules": {},

  "env": {
    "builtin": true
  }
}
